# Gemini API key / Vertex Express API key
# Choose one based on your authentication method:

# --- Method 1: AI Studio Gemini API Key ---
# Get from https://aistudio.google.com/api-keys (no billing required for free tier)
# GEMINI_API_KEY=your-gemini-api-key

# --- Method 2: Vertex AI Express Mode API Key ---
# Get from https://console.cloud.google.com/agent-platform/overview (uses Google Cloud billing)
# VERTEX_EXPRESS_MODE_API_KEY=your-vertex-express-api-key
# USE_VERTEX_AI=true

# --- Method 3: Vertex AI with ADC ---
# Requires: gcloud auth application-default login
# USE_VERTEX_AI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Method 4: Vertex AI with Service Account ---
# USE_VERTEX_AI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# --- Optional ---
# GEMINI_MODEL=gemini-2.5-flash
